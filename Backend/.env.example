# Exemplo de configuracao do backend.
# Copie este arquivo para .env e preencha com os dados do seu computador.

PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestor_eleitoral
DB_USER=gestor_app
DB_PASSWORD=troque_esta_senha
DB_SSL=false
# Mantenha true em producao. Use false apenas com um provedor que exija certificado proprio.
DB_SSL_REJECT_UNAUTHORIZED=true

# Em Render/Railway, voce pode usar DATABASE_URL no lugar das cinco variaveis DB_*.
# Nao preencha as duas formas ao mesmo tempo.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco
# DATABASE_MIGRATION_URL=postgresql://usuario_migracao:senha@host:5432/banco
#
# Supabase no Render:
# - use a string do "Session pooler" para evitar problema de IPv6 em planos sem IPv4;
# - mantenha o parametro ?sslmode=require;
# - se aparecer SELF_SIGNED_CERT_IN_CHAIN, defina DB_SSL_REJECT_UNAUTHORIZED=false no Render;
# - se usar DB_* em vez de DATABASE_URL, defina DB_SSL=true.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA_URL_ENCODED@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Lista separada por virgulas. Use apenas enderecos conhecidos.
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false

JWT_SECRET=gere_uma_chave_aleatoria_com_pelo_menos_64_caracteres_em_producao
JWT_EXPIRES_IN=3600
JWT_ISSUER=gestor-eleitoral-api
JWT_AUDIENCE=gestor-eleitoral-web

# Depois de criar a primeira conta, use false se o sistema for privado.
ALLOW_PUBLIC_REGISTRATION=true

# Preencha no terminal apenas ao executar o seed do primeiro administrador global.
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_CAMPAIGN_ID=
ADMIN_PASSWORD=

# Ative apenas durante um diagnostico local. Os logs mascaram o CPF e nunca devem ficar ativos em producao.
DEBUG_IMPORTACAO_CPF=false

# Use uma chave aleatoria diferente do JWT_SECRET para cifrar segredos MFA.
MFA_ENCRYPTION_KEY=gere_uma_chave_aleatoria_com_pelo_menos_64_caracteres

# Recuperacao de senha por e-mail.
FRONTEND_URL=http://localhost:5173

# Opcao 1: SMTP do seu dominio/provedor (ex.: Hostinger).
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=seguranca@seudominio.com
# SMTP_PASS=senha_da_caixa_de_email
# PASSWORD_RESET_FROM=Gestor Eleitoral <seguranca@seudominio.com>

# Opcao 2: Resend.
# RESEND_API_KEY=re_xxxxxxxxx
# PASSWORD_RESET_FROM=Gestor Eleitoral <seguranca@seudominio.com>

# Webhook HTTPS opcional para alertas de erros internos em producao.
# ALERT_WEBHOOK_URL=https://monitoramento.example.com/webhook

# Em producao e modo real, esta URL deve usar HTTPS e nao conter credenciais.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_INSTANCE=gestor-eleitoral
EVOLUTION_API_KEY=preencha_somente_se_for_usar_whatsapp
WHATSAPP_SIMULATION_MODE=true
WHATSAPP_BULK_DELAY_MS=500
