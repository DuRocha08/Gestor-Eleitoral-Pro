{
  "name": "gestor-eleitoral-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ghpages": "vite build --mode ghpages && node scripts/gh-pages-404.cjs",
